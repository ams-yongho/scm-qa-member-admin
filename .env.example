# sym DB (Azure MySQL, staging)
# Example: mysql://USER:PASSWORD@HOST:3306/sym?sslaccept=strict
# NOTE: URL-encode special chars in PASSWORD (e.g. @ → %40).
# NOTE: host MUST contain "staging" or boot will be refused (set ALLOW_NON_STAGING=true to override).
SYM_DATABASE_URL="mysql://amassadminmysqlsym:PASSWORD@amass-staging-mysql-sym-01.mysql.database.azure.com:3306/sym?sslaccept=strict"

# audit DB (SQLite, mounted volume in production)
# NOTE: file: URLs are resolved RELATIVE TO prisma/audit/schema.prisma,
# so "../../data/audit.db" points to <project root>/data/audit.db.
# In Docker the absolute path file:/data/audit.db is used (set in docker-compose.yml).
AUDIT_DATABASE_URL="file:../../data/audit.db"

# Optional safety flags
# READ_ONLY=true            # block all mutations
# ALLOW_NON_STAGING=true    # bypass prod-DB guard (do NOT use in production)
