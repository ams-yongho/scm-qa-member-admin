// sym DB (Azure MySQL, staging) — read/write
// Pruned from `prisma db pull` to only the 5 tables this tool actually uses.
// To refresh: `pnpm prisma:pull:sym` then re-prune by hand.

generator client {
  provider      = "prisma-client-js"
  output        = "../../lib/db/sym/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("SYM_DATABASE_URL")
}

model partsfit_mall_buyer {
  id                          Int                           @id @default(autoincrement())
  type                        String?                       @db.VarChar(50)
  login_id                    String?                       @db.VarChar(255)
  password                    String?                       @db.VarChar(255)
  name                        String?                       @db.VarChar(50)
  phone_number                String?                       @db.VarChar(100)
  email                       String?                       @db.VarChar(255)
  bank_name                   String?                       @db.VarChar(100)
  bank_number                 String?                       @db.VarChar(255)
  bank_holder                 String?                       @db.VarChar(100)
  status                      String?                       @db.VarChar(50)
  marketing_use               Boolean?
  sms_use                     Boolean?
  email_use                   Boolean?
  car_unlimited               Boolean?
  max_car_limit               Int?
  created_at                  DateTime?                     @default(now()) @db.DateTime(0)
  created_by                  Int?
  updated_at                  DateTime?                     @default(now()) @db.DateTime(0)
  updated_by                  Int?
  partsfit_mall_buyer_address partsfit_mall_buyer_address[]
  partsfit_mall_buyer_car     partsfit_mall_buyer_car[]
  partsfit_mall_buyer_oauth   partsfit_mall_buyer_oauth[]
}

model partsfit_mall_buyer_address {
  id                  Int                 @id @default(autoincrement())
  buyer_id            Int
  address_name        String?             @db.VarChar(50)
  recipient_name      String?             @db.VarChar(50)
  phone_number        String?             @db.VarChar(50)
  tel_number          String?             @db.VarChar(50)
  zipcode             String?             @db.VarChar(10)
  address             String?             @db.VarChar(255)
  address_detail      String?             @db.VarChar(255)
  memo                String?             @db.VarChar(255)
  created_at          DateTime?           @default(now()) @db.DateTime(0)
  created_by          Int?
  updated_at          DateTime?           @default(now()) @db.DateTime(0)
  updated_by          Int?
  partsfit_mall_buyer partsfit_mall_buyer @relation(fields: [buyer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_buyer_address_buyer")

  @@index([buyer_id], map: "idx_buyer_address_buyer_id")
}

model partsfit_mall_buyer_car {
  id                  Int                 @id @default(autoincrement())
  buyer_id            Int
  registration_type   String              @db.VarChar(50)
  owner               String?             @db.VarChar(255)
  plate_number        String?             @db.VarChar(50)
  vin_code            String?             @db.VarChar(50)
  car_brand_id        Int?
  car_model_id        Int?
  car_year            String?             @db.VarChar(10)
  created_at          DateTime?           @default(now()) @db.DateTime(0)
  created_by          Int?
  updated_at          DateTime?           @default(now()) @db.DateTime(0)
  updated_by          Int?
  deleted_at          DateTime?           @db.DateTime(6)
  partsfit_mall_buyer partsfit_mall_buyer @relation(fields: [buyer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_buyer_car_buyer")

  @@index([buyer_id], map: "idx_buyer_car_buyer_id")
  @@index([deleted_at], map: "idx_buyer_car_deleted_at")
}

model partsfit_mall_buyer_oauth {
  id                  Int                 @id @default(autoincrement())
  buyer_id            Int
  provider            String              @db.VarChar(50)
  provider_user_id    String              @db.VarChar(255)
  provider_email      String?             @db.VarChar(255)
  created_at          DateTime?           @default(now()) @db.DateTime(0)
  updated_at          DateTime?           @default(now()) @db.DateTime(0)
  partsfit_mall_buyer partsfit_mall_buyer @relation(fields: [buyer_id], references: [id], onDelete: Cascade, map: "fk_buyer_oauth_buyer")

  @@unique([provider, provider_user_id], map: "uq_buyer_oauth_provider_user")
  @@index([buyer_id], map: "fk_buyer_oauth_buyer")
}

model partsfit_mall_buyer_withdraw {
  id                          Int       @id @default(autoincrement())
  buyer_id                    Int?
  withdrawn_at                DateTime? @db.DateTime(0)
  personal_purge_at           DateTime? @db.DateTime(0)
  personal_deleted            Boolean?
  order_payment_purge_at      DateTime? @db.DateTime(0)
  order_payment_deleted       Boolean?
  customer_complaint_purge_at DateTime? @db.DateTime(0)
  customer_complaint_deleted  Boolean?
  created_at                  DateTime? @default(now()) @db.DateTime(0)
}
